FROM node:20-alpine
WORKDIR /app
# Native module build deps (better-sqlite3 in the shared agents deps has no musl prebuilt binaries)
RUN apk add --no-cache python3 make g++ libc6-compat
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
ENV ELFA_SKILL_PORT=3007
EXPOSE 3007
CMD ["node_modules/.bin/tsx", "src/elfa-skills.ts", "--serve"]
